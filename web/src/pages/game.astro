---
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>gl1tch-mud</title>
    <style is:global>
      *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

      :root {
        --bg:      #282a36;
        --bg-dark: #1e1f29;
        --bg-mid:  #21222c;
        --fg:      #f8f8f2;
        --comment: #6272a4;
        --cyan:    #8be9fd;
        --green:   #50fa7b;
        --orange:  #ffb86c;
        --pink:    #ff79c6;
        --purple:  #bd93f9;
        --red:     #ff5555;
        --yellow:  #f1fa8c;
        --border:  #44475a;
      }

      html, body {
        height: 100%;
        background: var(--bg);
        color: var(--fg);
        font-family: 'JetBrains Mono', 'Fira Code', 'Cascadia Code', 'Courier New', monospace;
        overflow: hidden;
      }

      /* ── Login ───────────────────────────────────────────── */
      #login-screen {
        display: flex;
        align-items: center;
        justify-content: center;
        height: 100%;
        background: radial-gradient(ellipse at center, #21222c 0%, #1e1f29 100%);
      }

      .login-card {
        border: 1px solid var(--purple);
        box-shadow: 0 0 24px rgba(189,147,249,0.15);
        padding: 2rem 2.5rem;
        width: 100%;
        max-width: 380px;
        background: var(--bg-dark);
      }

      .login-card h1 {
        font-size: 1.5rem;
        color: var(--cyan);
        letter-spacing: 0.1em;
        margin-bottom: 0.15rem;
      }

      .login-card .tagline {
        font-size: 0.7rem;
        color: var(--comment);
        margin-bottom: 1.5rem;
      }

      .login-card label {
        display: block;
        font-size: 0.7rem;
        color: var(--comment);
        margin-bottom: 0.25rem;
        letter-spacing: 0.08em;
        text-transform: uppercase;
      }

      .login-card input {
        width: 100%;
        background: var(--bg);
        border: 1px solid var(--comment);
        color: var(--fg);
        font-family: inherit;
        font-size: 0.9rem;
        padding: 0.5rem 0.6rem;
        outline: none;
        margin-bottom: 1rem;
        transition: border-color 0.15s;
      }

      .login-card input:focus { border-color: var(--purple); }

      .login-card button {
        width: 100%;
        background: var(--purple);
        color: var(--bg-dark);
        border: none;
        font-family: inherit;
        font-size: 0.9rem;
        font-weight: bold;
        padding: 0.65rem;
        cursor: pointer;
        letter-spacing: 0.08em;
        text-transform: uppercase;
        transition: background 0.15s;
      }

      .login-card button:hover { background: var(--pink); }

      #login-error {
        color: var(--red);
        font-size: 0.75rem;
        margin-top: 0.75rem;
        min-height: 1.1em;
      }

      /* ── HUD layout ─────────────────────────────────────── */
      #hud-screen {
        display: none;
        height: 100vh;
        width: 100vw;
        grid-template-rows: 2.4rem 1fr 2.8rem;
        grid-template-columns: 1fr 268px;
        grid-template-areas:
          "topbar topbar"
          "output sidebar"
          "input  input";
      }

      #hud-screen.active { display: grid; }

      /* ── Top bar ────────────────────────────────────────── */
      #topbar {
        grid-area: topbar;
        background: var(--bg-dark);
        border-bottom: 1px solid var(--border);
        display: flex;
        align-items: center;
        gap: 0.75rem;
        padding: 0 0.75rem;
        font-size: 0.8rem;
        overflow: hidden;
      }

      #topbar .logo {
        color: var(--cyan);
        font-weight: bold;
        letter-spacing: 0.1em;
        white-space: nowrap;
      }

      #topbar .sep { color: var(--border); flex-shrink: 0; }

      #room-name {
        color: var(--purple);
        flex: 1;
        overflow: hidden;
        text-overflow: ellipsis;
        white-space: nowrap;
      }

      #hp-display {
        display: flex;
        align-items: center;
        gap: 0.3rem;
        white-space: nowrap;
      }

      #hp-hearts { letter-spacing: 0.05em; }
      #hp-text   { color: var(--comment); font-size: 0.72rem; }

      #credits-display { color: var(--yellow); white-space: nowrap; }

      /* ── Game output ────────────────────────────────────── */
      #output {
        grid-area: output;
        background: var(--bg-dark);
        border-right: 1px solid var(--border);
        overflow-y: auto;
        padding: 0.6rem 0.75rem;
        font-size: 13px;
        line-height: 1.55;
        word-break: break-word;
      }

      #output::-webkit-scrollbar { width: 5px; }
      #output::-webkit-scrollbar-track { background: var(--bg-dark); }
      #output::-webkit-scrollbar-thumb { background: var(--border); border-radius: 3px; }

      /* ── Sidebar ────────────────────────────────────────── */
      #sidebar {
        grid-area: sidebar;
        background: var(--bg);
        display: flex;
        flex-direction: column;
        gap: 0;
        overflow-y: auto;
      }

      #sidebar::-webkit-scrollbar { width: 3px; }
      #sidebar::-webkit-scrollbar-thumb { background: var(--border); border-radius: 2px; }

      .panel {
        padding: 0.5rem 0.6rem;
        border-bottom: 1px solid var(--border);
      }

      .panel-title {
        font-size: 0.6rem;
        color: var(--comment);
        text-transform: uppercase;
        letter-spacing: 0.12em;
        margin-bottom: 0.4rem;
      }

      /* ── Compass ────────────────────────────────────────── */
      .compass-wrap {
        display: flex;
        justify-content: center;
      }

      .compass-grid {
        display: grid;
        grid-template-columns: repeat(3, 2.4rem);
        grid-template-rows: repeat(3, 2.4rem);
        gap: 3px;
      }

      .compass-btn {
        background: var(--bg-dark);
        border: 1px solid var(--border);
        color: var(--comment);
        font-family: inherit;
        font-size: 1.1rem;
        cursor: not-allowed;
        display: flex;
        align-items: center;
        justify-content: center;
        user-select: none;
        border-radius: 3px;
        transition: background 0.1s, color 0.1s, border-color 0.1s, box-shadow 0.1s;
      }

      .compass-btn.active {
        color: var(--cyan);
        border-color: var(--cyan);
        cursor: pointer;
      }

      .compass-btn.active:hover {
        background: rgba(139,233,253,0.12);
        box-shadow: 0 0 8px rgba(139,233,253,0.3);
      }

      .compass-btn.center {
        color: var(--purple);
        border-color: var(--purple);
        cursor: pointer;
        font-size: 0.9rem;
      }

      .compass-btn.center:hover {
        background: rgba(189,147,249,0.12);
        box-shadow: 0 0 8px rgba(189,147,249,0.3);
      }

      .compass-blank { /* empty corner */ }

      /* ── Network ────────────────────────────────────────── */
      #player-list {
        display: flex;
        flex-direction: column;
        gap: 4px;
      }

      .player-row {
        display: flex;
        align-items: center;
        gap: 0.5rem;
        background: var(--bg-dark);
        border: 1px solid var(--border);
        border-radius: 4px;
        padding: 4px 6px;
      }

      .player-avatar {
        width: 22px;
        height: 22px;
        border-radius: 3px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 0.65rem;
        font-weight: bold;
        flex-shrink: 0;
        text-transform: uppercase;
      }

      .player-avatar.host-av  { background: rgba(80,250,123,0.2);  color: var(--green);  }
      .player-avatar.peer-av  { background: rgba(139,233,253,0.2); color: var(--cyan);   }

      .player-info {
        flex: 1;
        min-width: 0;
      }

      .player-name {
        font-size: 0.72rem;
        font-weight: bold;
        overflow: hidden;
        text-overflow: ellipsis;
        white-space: nowrap;
      }

      .player-name.host-name { color: var(--green); }
      .player-name.peer-name { color: var(--cyan);  }

      .player-status {
        font-size: 0.58rem;
        color: var(--comment);
        overflow: hidden;
        text-overflow: ellipsis;
        white-space: nowrap;
      }

      .online-dot {
        width: 6px;
        height: 6px;
        border-radius: 50%;
        flex-shrink: 0;
      }

      .online-dot.host-dot {
        background: var(--green);
        box-shadow: 0 0 4px var(--green);
        animation: pulse-green 2s ease-in-out infinite;
      }

      .online-dot.peer-dot {
        background: var(--cyan);
        box-shadow: 0 0 4px var(--cyan);
      }

      .online-dot.offline-dot {
        background: var(--border);
      }

      @keyframes pulse-green {
        0%, 100% { box-shadow: 0 0 3px var(--green); }
        50%       { box-shadow: 0 0 8px var(--green); }
      }

      .goto-btn {
        background: none;
        border: 1px solid var(--border);
        color: var(--comment);
        font-family: inherit;
        font-size: 0.65rem;
        padding: 1px 5px;
        border-radius: 3px;
        cursor: pointer;
        flex-shrink: 0;
        transition: border-color 0.1s, color 0.1s;
        white-space: nowrap;
      }

      .goto-btn:hover {
        border-color: var(--purple);
        color: var(--purple);
      }

      /* ── Chat ────────────────────────────────────────────── */
      #chat-messages {
        max-height: 90px;
        overflow-y: auto;
        margin-bottom: 4px;
        display: flex;
        flex-direction: column;
        gap: 2px;
      }

      #chat-messages::-webkit-scrollbar { width: 3px; }
      #chat-messages::-webkit-scrollbar-thumb { background: var(--border); border-radius: 2px; }

      .chat-line {
        font-size: 0.68rem;
        line-height: 1.3;
        word-break: break-word;
      }

      .chat-line .chat-from {
        font-weight: bold;
      }

      .chat-line.from-host .chat-from { color: var(--green); }
      .chat-line.from-peer .chat-from { color: var(--cyan); }
      .chat-line .chat-text           { color: var(--fg); }

      .chat-input-row {
        display: flex;
        gap: 4px;
      }

      #chat-input {
        flex: 1;
        background: var(--bg-dark);
        border: 1px solid var(--border);
        color: var(--fg);
        font-family: inherit;
        font-size: 0.72rem;
        padding: 3px 6px;
        outline: none;
        border-radius: 3px;
        transition: border-color 0.1s;
      }

      #chat-input:focus { border-color: var(--cyan); }

      #chat-send-btn {
        background: var(--bg-dark);
        border: 1px solid var(--border);
        color: var(--cyan);
        font-family: inherit;
        font-size: 0.75rem;
        padding: 2px 8px;
        border-radius: 3px;
        cursor: pointer;
        flex-shrink: 0;
        transition: background 0.1s, border-color 0.1s;
      }

      #chat-send-btn:hover { background: rgba(139,233,253,0.1); border-color: var(--cyan); }

      /* ── Inventory ──────────────────────────────────────── */
      .inv-grid {
        display: grid;
        grid-template-columns: repeat(4, 1fr);
        gap: 4px;
      }

      .inv-slot {
        aspect-ratio: 1;
        background: var(--bg-dark);
        border: 2px solid var(--border);
        border-radius: 4px;
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        cursor: default;
        user-select: none;
        position: relative;
        transition: border-color 0.1s, box-shadow 0.1s;
        overflow: hidden;
        padding: 2px;
      }

      .inv-slot .slot-icon {
        font-size: 1.1rem;
        line-height: 1;
        margin-bottom: 1px;
      }

      .inv-slot .slot-label {
        font-size: 0.42rem;
        text-align: center;
        line-height: 1.1;
        overflow: hidden;
        max-width: 100%;
        white-space: nowrap;
        text-overflow: ellipsis;
        padding: 0 1px;
        color: var(--comment);
      }

      .inv-slot.occupied {
        cursor: pointer;
      }

      .inv-slot.occupied:hover {
        box-shadow: 0 0 10px currentColor;
      }

      .inv-slot.occupied[draggable="true"] {
        cursor: grab;
      }

      .inv-slot.dragging {
        opacity: 0.4;
        cursor: grabbing;
      }

      /* Tier colours */
      .inv-slot[data-tier="noise"]    { border-color: var(--border);  color: var(--comment); }
      .inv-slot[data-tier="signal"]   { border-color: #2d6e7a; color: var(--cyan);   }
      .inv-slot[data-tier="ghost"]    { border-color: #4a3070; color: var(--purple); }
      .inv-slot[data-tier="zero-day"] { border-color: #6e4a1a; color: var(--orange); }
      .inv-slot[data-tier="flatline"] { border-color: #6e1a1a; color: var(--red);    }

      /* ── Actions ────────────────────────────────────────── */
      .action-grid {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 4px;
      }

      .action-btn {
        background: var(--bg-dark);
        border: 1px solid var(--border);
        color: var(--fg);
        font-family: inherit;
        font-size: 0.68rem;
        padding: 0.3rem 0.4rem;
        border-radius: 4px;
        cursor: pointer;
        display: flex;
        align-items: center;
        gap: 0.35rem;
        white-space: nowrap;
        transition: background 0.1s, border-color 0.1s, color 0.1s;
      }

      .action-btn:hover {
        border-color: var(--purple);
        color: var(--purple);
        background: rgba(189,147,249,0.08);
      }

      .action-btn .btn-icon {
        font-size: 0.85rem;
        flex-shrink: 0;
      }

      .action-btn.craft-btn:hover {
        border-color: var(--orange);
        color: var(--orange);
        background: rgba(255,184,108,0.08);
      }

      /* ── Input bar ──────────────────────────────────────── */
      #input-bar {
        grid-area: input;
        background: var(--bg-dark);
        border-top: 1px solid var(--border);
        display: flex;
        align-items: center;
        gap: 0.5rem;
        padding: 0 0.6rem;
      }

      #input-bar .prompt {
        color: var(--green);
        font-size: 0.9rem;
        flex-shrink: 0;
      }

      #cmd-input {
        flex: 1;
        background: transparent;
        border: none;
        outline: none;
        color: var(--fg);
        font-family: inherit;
        font-size: 0.88rem;
        caret-color: var(--purple);
      }

      #send-btn {
        background: var(--purple);
        color: var(--bg-dark);
        border: none;
        font-family: inherit;
        font-size: 0.78rem;
        font-weight: bold;
        padding: 0.32rem 0.8rem;
        cursor: pointer;
        border-radius: 3px;
        letter-spacing: 0.04em;
        flex-shrink: 0;
        transition: background 0.1s;
      }

      #send-btn:hover    { background: var(--pink); }
      #send-btn:disabled { background: var(--comment); cursor: not-allowed; }

      /* ── Modals ─────────────────────────────────────────── */
      .modal-overlay {
        position: fixed;
        inset: 0;
        background: rgba(0,0,0,0.72);
        z-index: 200;
        display: none;
        align-items: center;
        justify-content: center;
      }

      .modal-overlay.open { display: flex; }

      .modal-box {
        background: var(--bg-dark);
        border: 1px solid var(--purple);
        box-shadow: 0 0 32px rgba(189,147,249,0.25);
        padding: 1.25rem 1.5rem;
        width: 90%;
        max-width: 340px;
        border-radius: 4px;
        position: relative;
      }

      .modal-close {
        position: absolute;
        top: 0.5rem;
        right: 0.6rem;
        background: none;
        border: none;
        color: var(--comment);
        font-family: inherit;
        font-size: 1rem;
        cursor: pointer;
        line-height: 1;
      }

      .modal-close:hover { color: var(--red); }

      .modal-title {
        font-size: 0.65rem;
        color: var(--comment);
        text-transform: uppercase;
        letter-spacing: 0.1em;
        margin-bottom: 0.75rem;
      }

      /* ── Item modal ─────────────────────────────────────── */
      #item-modal .item-header {
        display: flex;
        align-items: center;
        gap: 0.75rem;
        margin-bottom: 0.75rem;
      }

      #item-modal .item-big-icon {
        font-size: 2.2rem;
        line-height: 1;
        flex-shrink: 0;
        width: 3rem;
        height: 3rem;
        background: var(--bg);
        border: 2px solid var(--border);
        border-radius: 6px;
        display: flex;
        align-items: center;
        justify-content: center;
      }

      #item-modal .item-meta { flex: 1; min-width: 0; }

      #item-modal .item-name {
        font-size: 0.95rem;
        font-weight: bold;
        color: var(--fg);
        margin-bottom: 0.2rem;
      }

      #item-modal .item-tier {
        display: inline-block;
        font-size: 0.6rem;
        padding: 1px 6px;
        border-radius: 3px;
        text-transform: uppercase;
        letter-spacing: 0.07em;
      }

      .tier-badge-noise    { background: rgba(98,114,164,0.3);  color: var(--comment); border: 1px solid var(--border);  }
      .tier-badge-signal   { background: rgba(139,233,253,0.15); color: var(--cyan);   border: 1px solid #2d6e7a; }
      .tier-badge-ghost    { background: rgba(189,147,249,0.15); color: var(--purple); border: 1px solid #4a3070; }
      .tier-badge-zero-day { background: rgba(255,184,108,0.15); color: var(--orange); border: 1px solid #6e4a1a; }
      .tier-badge-flatline { background: rgba(255,85,85,0.15);   color: var(--red);    border: 1px solid #6e1a1a; }

      #item-modal .item-desc {
        font-size: 0.75rem;
        color: var(--comment);
        line-height: 1.5;
        margin-bottom: 1rem;
        min-height: 2.5em;
      }

      .item-actions {
        display: flex;
        gap: 6px;
      }

      .item-actions button {
        flex: 1;
        background: var(--bg);
        border: 1px solid var(--border);
        color: var(--fg);
        font-family: inherit;
        font-size: 0.72rem;
        padding: 0.35rem 0.4rem;
        cursor: pointer;
        border-radius: 3px;
        transition: background 0.1s, border-color 0.1s, color 0.1s;
      }

      #item-examine-btn:hover { border-color: var(--cyan);   color: var(--cyan);   background: rgba(139,233,253,0.08); }
      #item-use-btn:hover     { border-color: var(--green);  color: var(--green);  background: rgba(80,250,123,0.08);  }
      #item-drop-btn:hover    { border-color: var(--red);    color: var(--red);    background: rgba(255,85,85,0.08);   }

      /* ── Craft modal ────────────────────────────────────── */
      #craft-modal .craft-layout {
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 0.75rem;
        margin-bottom: 0.75rem;
      }

      .craft-grid {
        display: grid;
        grid-template-columns: repeat(3, 2.5rem);
        grid-template-rows: repeat(3, 2.5rem);
        gap: 3px;
      }

      .craft-slot {
        background: var(--bg);
        border: 2px solid var(--border);
        border-radius: 3px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1rem;
        color: var(--border);
        cursor: pointer;
        transition: border-color 0.1s;
      }

      .craft-slot:hover { border-color: var(--comment); }
      .craft-slot.filled { border-color: var(--purple); color: var(--fg); cursor: pointer; }
      .craft-slot.filled:hover { border-color: var(--red); }

      .craft-slot.drag-over {
        border-color: var(--green);
        background: rgba(80,250,123,0.1);
        box-shadow: 0 0 8px rgba(80,250,123,0.4);
      }

      .craft-slot-icon {
        display: block;
        font-size: 0.9rem;
        line-height: 1;
      }

      .craft-slot-label {
        display: block;
        font-size: 0.38rem;
        color: var(--comment);
        text-align: center;
        overflow: hidden;
        white-space: nowrap;
        text-overflow: ellipsis;
        max-width: 100%;
      }

      .craft-arrow {
        font-size: 1.2rem;
        color: var(--comment);
        flex-shrink: 0;
      }

      .craft-output {
        width: 3.5rem;
        height: 3.5rem;
        background: var(--bg);
        border: 2px solid var(--border);
        border-radius: 4px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1.4rem;
        flex-shrink: 0;
      }

      #craft-modal .craft-hint {
        font-size: 0.7rem;
        color: var(--comment);
        text-align: center;
        margin-bottom: 0.75rem;
        line-height: 1.4;
      }

      #craft-do-btn {
        width: 100%;
        background: var(--orange);
        color: var(--bg-dark);
        border: none;
        font-family: inherit;
        font-size: 0.8rem;
        font-weight: bold;
        padding: 0.5rem;
        cursor: pointer;
        border-radius: 3px;
        letter-spacing: 0.05em;
        transition: background 0.1s;
      }

      #craft-do-btn:hover { background: var(--yellow); }
    </style>
  </head>
  <body>
    <!-- Login -->
    <div id="login-screen">
      <div class="login-card">
        <h1 id="login-world-name">gl1tch-mud</h1>
        <p class="tagline">jack in. ghost the gibson. don't get traced.</p>

        <label for="player-name">handle</label>
        <input id="player-name" type="text" placeholder="nova" autocomplete="off" autocapitalize="off" spellcheck="false" maxlength="20" />

        <label for="passphrase">passphrase</label>
        <input id="passphrase" type="password" placeholder="(leave blank if none)" />

        <button id="connect-btn">connect</button>
        <div id="login-error"></div>
      </div>
    </div>

    <!-- HUD -->
    <div id="hud-screen">
      <!-- Top bar -->
      <div id="topbar">
        <span class="logo" id="topbar-world">gl1tch</span>
        <span class="sep">|</span>
        <span id="room-name">—</span>
        <span class="sep">|</span>
        <div id="hp-display">
          <span id="hp-hearts">♥♥♥♥♥</span>
          <span id="hp-text">100/100</span>
        </div>
        <span class="sep">|</span>
        <span id="credits-display">¢ 0</span>
      </div>

      <!-- Game output -->
      <div id="output"></div>

      <!-- Sidebar -->
      <div id="sidebar">

        <!-- Compass -->
        <div class="panel">
          <div class="panel-title">navigate</div>
          <div class="compass-wrap">
            <div class="compass-grid">
              <div class="compass-blank"></div>
              <button class="compass-btn" id="btn-n" title="North">↑</button>
              <div class="compass-blank"></div>
              <button class="compass-btn" id="btn-w" title="West">←</button>
              <button class="compass-btn center" id="btn-look" title="Look around">👁</button>
              <button class="compass-btn" id="btn-e" title="East">→</button>
              <div class="compass-blank"></div>
              <button class="compass-btn" id="btn-s" title="South">↓</button>
              <div class="compass-blank"></div>
            </div>
          </div>
        </div>

        <!-- Room Context (kids mode only) -->
        <div class="panel" id="room-context">
          <div class="panel-title">who's here</div>
          <div id="room-npcs-list"></div>
          <div class="panel-title kids-section-sep">exits</div>
          <div id="kids-exits"></div>
        </div>

        <!-- Network -->
        <div class="panel">
          <div class="panel-title">network</div>
          <div id="player-list">
            <!-- populated by JS -->
          </div>
        </div>

        <!-- Chat -->
        <div class="panel" id="chat-panel">
          <div class="panel-title">chat</div>
          <div id="chat-messages"></div>
          <div class="chat-input-row">
            <input id="chat-input" type="text" placeholder="say something..." maxlength="200" autocomplete="off" autocapitalize="off" spellcheck="false" />
            <button id="chat-send-btn">→</button>
          </div>
        </div>

        <!-- Inventory -->
        <div class="panel">
          <div class="panel-title">inventory</div>
          <div class="inv-grid" id="inv-grid">
            <!-- 8 slots rendered by JS -->
          </div>
        </div>

        <!-- Actions -->
        <div class="panel">
          <div class="panel-title">actions</div>
          <div id="target-picker">
            <div class="picker-label" id="target-picker-label">choose a target</div>
            <div id="target-picker-btns"></div>
          </div>
          <div class="action-grid" id="action-grid">
            <!-- populated by JS based on world -->
          </div>
        </div>

      </div>

      <!-- Onboarding hint banner (kids mode only) -->
      <div id="hint-banner"></div>

      <!-- Input bar -->
      <div id="input-bar">
        <button id="kids-input-toggle" type="button" aria-label="Show/hide keyboard input" title="Show/hide keyboard input">⌨️</button>
        <span class="prompt">&gt;</span>
        <input id="cmd-input" type="text" autocomplete="off" autocapitalize="off" spellcheck="false" placeholder="type a command..." />
        <button id="send-btn">Send</button>
      </div>
    </div>

    <!-- Item detail modal -->
    <div class="modal-overlay" id="item-modal">
      <div class="modal-box">
        <button class="modal-close" id="item-modal-close">✕</button>
        <div class="modal-title">item</div>
        <div class="item-header">
          <div class="item-big-icon" id="item-big-icon">?</div>
          <div class="item-meta">
            <div class="item-name" id="item-name-display">—</div>
            <span class="item-tier" id="item-tier-badge">noise</span>
          </div>
        </div>
        <div class="item-desc" id="item-desc-display">—</div>
        <div class="item-actions">
          <button id="item-examine-btn">🔍 Examine</button>
          <button id="item-use-btn">▶ Use</button>
          <button id="item-drop-btn">🗑 Drop</button>
        </div>
      </div>
    </div>

    <!-- Craft modal -->
    <div class="modal-overlay" id="craft-modal">
      <div class="modal-box">
        <button class="modal-close" id="craft-modal-close">✕</button>
        <div class="modal-title">crafting table</div>
        <div class="craft-layout">
          <div class="craft-grid" id="craft-grid">
            <!-- 9 slots rendered by JS -->
          </div>
          <div class="craft-arrow">▶</div>
          <div class="craft-output" id="craft-output">?</div>
        </div>
        <p class="craft-hint" id="craft-hint">Drag items from your inventory into the grid.</p>
        <button id="craft-do-btn">🔧 Open Crafting Menu</button>
      </div>
    </div>

    <!-- Kids quest modal -->
    <div class="modal-overlay" id="quest-kids-modal">
      <div class="modal-box">
        <button class="modal-close" id="quest-kids-modal-close">✕</button>
        <div class="modal-title">your quests</div>
        <div id="quest-kids-list"></div>
      </div>
    </div>

    <script>
      import { setWorld, initMUD } from '../lib/mud.ts';

      const params = new URLSearchParams(window.location.search);
      const worldName = params.get('world');

      if (!worldName) {
        // No world param — redirect to lobby.
        window.location.replace('/');
      } else {
        const nameEl   = document.getElementById('login-world-name');
        const topbarEl = document.getElementById('topbar-world');
        if (nameEl)   nameEl.textContent   = worldName;
        if (topbarEl) topbarEl.textContent = worldName;

        setWorld(worldName);
        initMUD();
      }
    </script>
  </body>
</html>
