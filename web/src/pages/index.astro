---
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>gl1tch-mud</title>
    <style>
      *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

      :root {
        --bg:      #282a36;
        --bg-dark: #1e1f29;
        --fg:      #f8f8f2;
        --comment: #6272a4;
        --cyan:    #8be9fd;
        --green:   #50fa7b;
        --orange:  #ffb86c;
        --pink:    #ff79c6;
        --purple:  #bd93f9;
        --red:     #ff5555;
        --yellow:  #f1fa8c;
        --border:  #44475a;
      }

      html, body {
        height: 100%;
        background: var(--bg);
        color: var(--fg);
        font-family: 'JetBrains Mono', 'Fira Code', 'Cascadia Code', 'Courier New', monospace;
        overflow: hidden;
      }

      /* ── Login ─────────────────────────────────────────── */
      #login-screen {
        display: flex;
        align-items: center;
        justify-content: center;
        height: 100%;
      }

      .login-card {
        border: 1px solid var(--purple);
        padding: 2rem 2.5rem;
        width: 100%;
        max-width: 380px;
        background: var(--bg-dark);
      }

      .login-card h1 {
        font-size: 1.4rem;
        color: var(--cyan);
        letter-spacing: 0.08em;
        margin-bottom: 0.25rem;
      }

      .login-card .tagline {
        font-size: 0.75rem;
        color: var(--comment);
        margin-bottom: 1.5rem;
      }

      .login-card label {
        display: block;
        font-size: 0.75rem;
        color: var(--comment);
        margin-bottom: 0.25rem;
        letter-spacing: 0.05em;
        text-transform: uppercase;
      }

      .login-card input {
        width: 100%;
        background: var(--bg);
        border: 1px solid var(--comment);
        color: var(--fg);
        font-family: inherit;
        font-size: 0.95rem;
        padding: 0.5rem 0.6rem;
        outline: none;
        margin-bottom: 1rem;
      }

      .login-card input:focus {
        border-color: var(--purple);
      }

      .login-card button {
        width: 100%;
        background: var(--purple);
        color: var(--bg);
        border: none;
        font-family: inherit;
        font-size: 0.9rem;
        font-weight: bold;
        padding: 0.6rem;
        cursor: pointer;
        letter-spacing: 0.06em;
        text-transform: uppercase;
      }

      .login-card button:hover {
        background: var(--pink);
      }

      #login-error {
        color: var(--red);
        font-size: 0.8rem;
        margin-top: 0.75rem;
        min-height: 1.1em;
      }

      /* ── HUD ────────────────────────────────────────────── */
      #hud-screen {
        display: none;
        height: 100vh;
        width: 100vw;
        grid-template-rows: 2.2rem 1fr 2.8rem;
        grid-template-columns: 1fr 280px;
        grid-template-areas:
          "topbar topbar"
          "output sidebar"
          "input  input";
      }

      #hud-screen.active {
        display: grid;
      }

      /* ── Top bar ──────────────────────────────────────── */
      #topbar {
        grid-area: topbar;
        background: var(--bg-dark);
        border-bottom: 1px solid var(--border);
        display: flex;
        align-items: center;
        gap: 1rem;
        padding: 0 0.75rem;
        font-size: 0.8rem;
        overflow: hidden;
      }

      #topbar .logo {
        color: var(--cyan);
        font-weight: bold;
        letter-spacing: 0.08em;
        white-space: nowrap;
      }

      #topbar .sep { color: var(--border); }

      #room-name {
        color: var(--purple);
        flex: 1;
        overflow: hidden;
        text-overflow: ellipsis;
        white-space: nowrap;
      }

      #hp-display {
        display: flex;
        align-items: center;
        gap: 0.35rem;
        white-space: nowrap;
      }

      #hp-hearts { letter-spacing: 0.05em; }
      #hp-text   { color: var(--comment); font-size: 0.75rem; }

      #credits-display {
        color: var(--yellow);
        white-space: nowrap;
      }

      /* ── Game output ─────────────────────────────────── */
      #output {
        grid-area: output;
        background: var(--bg-dark);
        border-right: 1px solid var(--border);
        overflow-y: auto;
        padding: 0.6rem 0.75rem;
        font-size: 13px;
        line-height: 1.5;
        word-break: break-word;
      }

      #output::-webkit-scrollbar { width: 6px; }
      #output::-webkit-scrollbar-track { background: var(--bg-dark); }
      #output::-webkit-scrollbar-thumb { background: var(--border); border-radius: 3px; }

      /* ── Sidebar ─────────────────────────────────────── */
      #sidebar {
        grid-area: sidebar;
        background: var(--bg);
        display: flex;
        flex-direction: column;
        gap: 0.6rem;
        padding: 0.6rem 0.6rem;
        overflow-y: auto;
      }

      #sidebar::-webkit-scrollbar { width: 4px; }
      #sidebar::-webkit-scrollbar-thumb { background: var(--border); border-radius: 2px; }

      .panel-title {
        font-size: 0.65rem;
        color: var(--comment);
        text-transform: uppercase;
        letter-spacing: 0.1em;
        margin-bottom: 0.35rem;
      }

      /* ── Compass ─────────────────────────────────────── */
      #compass-panel {}

      .compass-grid {
        display: grid;
        grid-template-columns: repeat(3, 2rem);
        grid-template-rows: repeat(3, 2rem);
        gap: 2px;
        justify-content: center;
      }

      .compass-btn {
        width: 2rem;
        height: 2rem;
        background: var(--bg-dark);
        border: 1px solid var(--border);
        color: var(--comment);
        font-family: inherit;
        font-size: 0.7rem;
        cursor: not-allowed;
        display: flex;
        align-items: center;
        justify-content: center;
        user-select: none;
        transition: background 0.1s, color 0.1s;
      }

      .compass-btn.active {
        color: var(--cyan);
        border-color: var(--cyan);
        cursor: pointer;
      }

      .compass-btn.active:hover {
        background: #1a3a40;
      }

      .compass-btn.center {
        color: var(--purple);
        border-color: var(--purple);
        cursor: pointer;
      }

      .compass-btn.center:hover {
        background: #2a1f40;
      }

      .compass-blank {
        width: 2rem;
        height: 2rem;
      }

      /* ── Inventory ───────────────────────────────────── */
      #inv-panel {}

      .inv-grid {
        display: grid;
        grid-template-columns: repeat(4, 1fr);
        gap: 3px;
      }

      .inv-slot {
        aspect-ratio: 1;
        background: var(--bg-dark);
        border: 1px solid var(--border);
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 0.55rem;
        color: var(--comment);
        text-align: center;
        overflow: hidden;
        padding: 2px;
        cursor: default;
        user-select: none;
        line-height: 1.2;
        word-break: break-word;
      }

      .inv-slot.occupied {
        cursor: pointer;
        border-color: var(--border);
      }

      .inv-slot.occupied:hover {
        border-color: var(--fg);
      }

      /* Tier colors */
      .inv-slot[data-tier="noise"]    { color: var(--comment); }
      .inv-slot[data-tier="signal"]   { color: var(--cyan); border-color: #2a5a60; }
      .inv-slot[data-tier="ghost"]    { color: var(--purple); border-color: #3a2a60; }
      .inv-slot[data-tier="zero-day"] { color: var(--orange); border-color: #604020; }
      .inv-slot[data-tier="flatline"] { color: var(--red); border-color: #602020; }

      /* ── Actions ─────────────────────────────────────── */
      #actions-panel {}

      .action-btn-row {
        display: flex;
        flex-wrap: wrap;
        gap: 4px;
        margin-bottom: 2px;
      }

      .action-btn {
        background: var(--bg-dark);
        border: 1px solid var(--border);
        color: var(--fg);
        font-family: inherit;
        font-size: 0.7rem;
        padding: 0.25rem 0.5rem;
        border-radius: 3px;
        cursor: pointer;
        white-space: nowrap;
        transition: background 0.1s, border-color 0.1s;
      }

      .action-btn:hover {
        background: var(--purple);
        border-color: var(--purple);
        color: var(--bg);
      }

      /* ── Input bar ───────────────────────────────────── */
      #input-bar {
        grid-area: input;
        background: var(--bg-dark);
        border-top: 1px solid var(--border);
        display: flex;
        align-items: center;
        gap: 0.5rem;
        padding: 0 0.6rem;
      }

      #input-bar .prompt {
        color: var(--green);
        font-size: 0.9rem;
        flex-shrink: 0;
      }

      #cmd-input {
        flex: 1;
        background: transparent;
        border: none;
        outline: none;
        color: var(--fg);
        font-family: inherit;
        font-size: 0.88rem;
        caret-color: var(--purple);
      }

      #send-btn {
        background: var(--purple);
        color: var(--bg);
        border: none;
        font-family: inherit;
        font-size: 0.8rem;
        font-weight: bold;
        padding: 0.3rem 0.75rem;
        cursor: pointer;
        border-radius: 3px;
        letter-spacing: 0.04em;
        flex-shrink: 0;
      }

      #send-btn:hover { background: var(--pink); }
      #send-btn:disabled { background: var(--comment); cursor: not-allowed; }
    </style>
  </head>
  <body>
    <!-- Login -->
    <div id="login-screen">
      <div class="login-card">
        <h1>gl1tch-mud</h1>
        <p class="tagline">jack in. ghost the gibson. don't get traced.</p>

        <label for="player-name">handle</label>
        <input id="player-name" type="text" placeholder="nova" autocomplete="off" autocapitalize="off" spellcheck="false" maxlength="20" />

        <label for="passphrase">passphrase</label>
        <input id="passphrase" type="password" placeholder="(leave blank if none)" />

        <button id="connect-btn">connect</button>
        <div id="login-error"></div>
      </div>
    </div>

    <!-- HUD -->
    <div id="hud-screen">
      <!-- Top bar -->
      <div id="topbar">
        <span class="logo">gl1tch-mud</span>
        <span class="sep">|</span>
        <span id="room-name">—</span>
        <span class="sep">|</span>
        <div id="hp-display">
          <span id="hp-hearts">♥♥♥♥♥</span>
          <span id="hp-text">100/100</span>
        </div>
        <span class="sep">|</span>
        <span id="credits-display">¢ 0</span>
      </div>

      <!-- Game output -->
      <div id="output"></div>

      <!-- Sidebar -->
      <div id="sidebar">
        <!-- Compass -->
        <div id="compass-panel">
          <div class="panel-title">compass</div>
          <div class="compass-grid">
            <div class="compass-blank"></div>
            <button class="compass-btn" data-dir="north" id="btn-n">[N]</button>
            <div class="compass-blank"></div>
            <button class="compass-btn" data-dir="west"  id="btn-w">[W]</button>
            <button class="compass-btn center"            id="btn-look">[+]</button>
            <button class="compass-btn" data-dir="east"  id="btn-e">[E]</button>
            <div class="compass-blank"></div>
            <button class="compass-btn" data-dir="south" id="btn-s">[S]</button>
            <div class="compass-blank"></div>
          </div>
        </div>

        <!-- Inventory -->
        <div id="inv-panel">
          <div class="panel-title">inventory</div>
          <div class="inv-grid" id="inv-grid">
            <!-- 8 slots rendered by JS -->
          </div>
        </div>

        <!-- Actions -->
        <div id="actions-panel">
          <div class="panel-title">actions</div>
          <div class="action-btn-row">
            <button class="action-btn" data-cmd="look">Look</button>
            <button class="action-btn" data-cmd="help">Help</button>
            <button class="action-btn" data-cmd="skills">Skills</button>
          </div>
          <div class="action-btn-row">
            <button class="action-btn" data-cmd="inventory">Inventory</button>
            <button class="action-btn" data-cmd="quests">Quests</button>
          </div>
        </div>
      </div>

      <!-- Input bar -->
      <div id="input-bar">
        <span class="prompt">&gt;</span>
        <input id="cmd-input" type="text" autocomplete="off" autocapitalize="off" spellcheck="false" placeholder="type a command..." />
        <button id="send-btn">Send</button>
      </div>
    </div>

    <script>
      import { initMUD } from '../lib/mud.ts';
      initMUD();
    </script>
  </body>
</html>
