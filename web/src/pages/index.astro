---
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>gl1tch-mud</title>
    <style is:global>
      *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

      :root {
        --bg:      #0d0d0f;
        --bg-card: #111115;
        --fg:      #e8e8f0;
        --dim:     #4a4a5e;
        --border:  #22222e;
        --purple:  #bd93f9;
        --cyan:    #8be9fd;
        --red:     #ff5555;
      }

      html, body {
        height: 100%;
        background: var(--bg);
        color: var(--fg);
        font-family: 'JetBrains Mono', 'Fira Code', 'Cascadia Code', 'Courier New', monospace;
        display: flex;
        align-items: center;
        justify-content: center;
      }

      #lobby {
        width: 100%;
        max-width: 560px;
        padding: 2.5rem 1.5rem;
      }

      .lobby-header {
        margin-bottom: 2rem;
      }

      .lobby-title {
        font-size: 1.1rem;
        color: var(--cyan);
        letter-spacing: 0.14em;
        margin-bottom: 0.3rem;
      }

      .lobby-sub {
        font-size: 0.68rem;
        color: var(--dim);
        letter-spacing: 0.05em;
      }

      #world-list {
        display: flex;
        flex-direction: column;
        gap: 2px;
      }

      .world-entry {
        display: flex;
        align-items: center;
        gap: 0.75rem;
        background: var(--bg-card);
        border: 1px solid var(--border);
        padding: 0.75rem 1rem;
        text-decoration: none;
        color: inherit;
        cursor: pointer;
        position: relative;
        overflow: hidden;
        transition: border-color 0.12s, background 0.12s;
      }

      .world-entry::before {
        content: '';
        position: absolute;
        left: 0;
        top: 0;
        bottom: 0;
        width: 3px;
        background: var(--entry-accent, var(--purple));
        opacity: 0;
        transition: opacity 0.12s;
      }

      .world-entry:hover,
      .world-entry.focused {
        border-color: var(--entry-accent, var(--purple));
        background: color-mix(in srgb, var(--entry-accent, var(--purple)) 5%, var(--bg-card));
      }

      .world-entry:hover::before,
      .world-entry.focused::before {
        opacity: 1;
      }

      .entry-index {
        font-size: 0.62rem;
        color: var(--dim);
        min-width: 1rem;
        text-align: right;
        flex-shrink: 0;
      }

      .entry-body {
        flex: 1;
        min-width: 0;
      }

      .entry-name {
        font-size: 0.88rem;
        font-weight: bold;
        letter-spacing: 0.04em;
        color: var(--entry-accent, var(--purple));
      }

      .entry-tagline {
        font-size: 0.64rem;
        color: var(--dim);
        overflow: hidden;
        text-overflow: ellipsis;
        white-space: nowrap;
      }

      .entry-badge {
        font-size: 0.56rem;
        color: var(--dim);
        border: 1px solid var(--border);
        padding: 0.05rem 0.35rem;
        border-radius: 2px;
        letter-spacing: 0.04em;
        white-space: nowrap;
      }

      .entry-badge.shared {
        color: var(--cyan);
        border-color: color-mix(in srgb, var(--cyan) 30%, transparent);
      }

      .entry-online {
        font-size: 0.56rem;
        color: var(--cyan);
        letter-spacing: 0.02em;
        white-space: nowrap;
      }

      .entry-name-row {
        display: flex;
        align-items: center;
        gap: 0.5rem;
        margin-bottom: 0.15rem;
      }

      .entry-arrow {
        font-size: 0.72rem;
        color: var(--dim);
        flex-shrink: 0;
        transition: color 0.12s, transform 0.12s;
      }

      .world-entry:hover .entry-arrow,
      .world-entry.focused .entry-arrow {
        color: var(--entry-accent, var(--purple));
        transform: translateX(3px);
      }

      .lobby-hint {
        margin-top: 1.25rem;
        font-size: 0.6rem;
        color: var(--dim);
        letter-spacing: 0.04em;
      }

      #status-msg {
        font-size: 0.75rem;
        color: var(--dim);
        padding: 0.5rem 0;
      }

      #error-msg {
        font-size: 0.72rem;
        color: var(--red);
        margin-top: 0.5rem;
      }
    </style>
  </head>
  <body>
    <div id="lobby">
      <div class="lobby-header">
        <div class="lobby-title">gl1tch-mud</div>
        <div class="lobby-sub">select a world to enter</div>
      </div>
      <div id="world-list">
        <p id="status-msg">loading worlds...</p>
      </div>
      <p id="error-msg"></p>
    </div>

    <script>
      (async () => {
        const list      = document.getElementById('world-list')!;
        const statusMsg = document.getElementById('status-msg')!;
        const errorMsg  = document.getElementById('error-msg')!;

        type WorldMeta = { name: string; tagline: string; mode?: string; online?: number; theme?: { accent?: string } };
        let worlds: WorldMeta[] = [];

        try {
          const res = await fetch('/api/worlds');
          if (!res.ok) throw new Error(`server returned ${res.status}`);
          worlds = await res.json();
        } catch (e: any) {
          statusMsg.remove();
          errorMsg.textContent = `failed to load worlds: ${e.message}`;
          return;
        }

        statusMsg.remove();

        if (worlds.length === 0) {
          const p = document.createElement('p');
          p.style.cssText = 'font-size:0.72rem;color:var(--dim);padding:0.5rem 0;';
          p.textContent = 'no worlds available.';
          list.appendChild(p);
          return;
        }

        // Single world: skip lobby and navigate directly.
        if (worlds.length === 1) {
          window.location.replace(`/game?world=${encodeURIComponent(worlds[0].name)}`);
          return;
        }

        const entries: HTMLAnchorElement[] = [];

        for (let i = 0; i < worlds.length; i++) {
          const w = worlds[i];
          const accent = w.theme?.accent ?? 'var(--purple)';

          const entry = document.createElement('a');
          entry.className = 'world-entry';
          entry.href = `/game?world=${encodeURIComponent(w.name)}`;
          entry.style.setProperty('--entry-accent', accent);

          const idx = document.createElement('div');
          idx.className = 'entry-index';
          idx.textContent = `${i + 1}`;

          const body = document.createElement('div');
          body.className = 'entry-body';

          const nameRow = document.createElement('div');
          nameRow.className = 'entry-name-row';

          const nameEl = document.createElement('span');
          nameEl.className = 'entry-name';
          nameEl.textContent = w.name;
          nameRow.appendChild(nameEl);

          const mode = w.mode || 'solo';
          const badge = document.createElement('span');
          badge.className = `entry-badge${mode === 'shared' ? ' shared' : ''}`;
          badge.textContent = mode;
          nameRow.appendChild(badge);

          if (mode === 'shared' && w.online && w.online > 0) {
            const onlineEl = document.createElement('span');
            onlineEl.className = 'entry-online';
            onlineEl.textContent = `${w.online} online`;
            nameRow.appendChild(onlineEl);
          }

          const tagEl = document.createElement('div');
          tagEl.className = 'entry-tagline';
          tagEl.textContent = w.tagline || '—';

          body.appendChild(nameRow);
          body.appendChild(tagEl);

          const arrow = document.createElement('div');
          arrow.className = 'entry-arrow';
          arrow.textContent = '→';

          entry.appendChild(idx);
          entry.appendChild(body);
          entry.appendChild(arrow);
          list.appendChild(entry);
          entries.push(entry);
        }

        // Show keyboard hint when there are multiple worlds.
        if (worlds.length > 1) {
          const hint = document.createElement('p');
          hint.className = 'lobby-hint';
          hint.textContent = `press 1–${Math.min(worlds.length, 9)} to select`;
          document.getElementById('lobby')!.appendChild(hint);
        }

        // Keyboard shortcuts 1-9.
        document.addEventListener('keydown', (e) => {
          const n = parseInt(e.key);
          if (!isNaN(n) && n >= 1 && n <= worlds.length) {
            window.location.href = entries[n - 1].href;
          }
        });
      })();
    </script>
  </body>
</html>
